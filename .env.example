# ===========================================
# Text-Me: Конфигурация окружения
# ===========================================

# Порт сервера (Render назначает автоматически)
PORT=3000

# ===========================================
# Supabase PostgreSQL (Connection Pooler)
# ===========================================
# Строка подключения к Supabase через PgBouncer
# Формат: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ===========================================
# Supabase API
# ===========================================
# URL проекта Supabase (для Storage API)
SUPABASE_URL=https://xxxxx.supabase.co

# Анонимный ключ (для клиентских запросов)
SUPABASE_ANON_KEY=eyJhbGciOi...

# Сервисный ключ (для серверных операций: удаление файлов из Storage)
SUPABASE_SERVICE_KEY=eyJhbGciOi...

# ===========================================
# Политика хранения данных
# ===========================================
# Через сколько дней удалять старые сообщения
RETENTION_DAYS_MESSAGES=3

# Через сколько дней удалять изображения (TTL при загрузке)
RETENTION_DAYS_IMAGES=3
